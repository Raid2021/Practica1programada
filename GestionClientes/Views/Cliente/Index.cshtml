@model List<ClienteDTO>

@{
    ViewData["Title"] = "Clientes";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Listado de Clientes</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Nuevo Cliente
    </a>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">
        No hay clientes registrados. <a asp-action="Create">Agregar el primero</a>.
    </div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>#</th>
                    <th>Cédula</th>
                    <th>Nombre</th>
                    <th>Apellidos</th>
                    <th class="text-center">Teléfonos</th>
                    <th class="text-center">Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var cliente in Model)
                {
                    <tr>
                        <td>@cliente.Id</td>
                        <td>@cliente.Cedula</td>
                        <td>@cliente.Nombre</td>
                        <td>@cliente.Apellidos</td>
                        <td class="text-center">
                            <span class="badge bg-secondary">@cliente.Telefonos.Count</span>
                        </td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@cliente.Id"
                               class="btn btn-sm btn-info text-white me-1" title="Ver detalle">
                                Detalle
                            </a>
                            <a asp-action="Edit" asp-route-id="@cliente.Id"
                               class="btn btn-sm btn-warning me-1" title="Editar">
                                Editar
                            </a>
                            <a asp-action="Delete" asp-route-id="@cliente.Id"
                               class="btn btn-sm btn-danger" title="Eliminar">
                                Eliminar
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
